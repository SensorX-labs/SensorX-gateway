# ─────────────────────────────────────────────────────────────────
#  SensorX Gateway — Environment Variables
#  Copy to .env and fill in your values.
#  NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────

# ── Domain ────────────────────────────────────────────────────────
# Base domain. Subdomains will be:
#   api.${DOMAIN}          → SensorX Gateway
#   grafana.${DOMAIN}      → Grafana
#   traefik.${DOMAIN}      → Traefik dashboard (protected)
#   prometheus.${DOMAIN}   → Prometheus (protected)
DOMAIN=yourdomain.com

# ── Let's Encrypt ─────────────────────────────────────────────────
# Email used for certificate expiry notifications
ACME_EMAIL=admin@yourdomain.com

# ── Traefik Dashboard Auth ─────────────────────────────────────────
# Generate password hash:
#   echo $(htpasswd -nb admin yourpassword) | sed -e s/\\$/\\$\\$/g
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD_HASH=$$apr1$$xxxxxxxx$$xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password

# ── Redis ─────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password

# ── JWT ───────────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_HMAC_SECRET=change-me-minimum-32-character-secret-key

# ── Grafana ───────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
