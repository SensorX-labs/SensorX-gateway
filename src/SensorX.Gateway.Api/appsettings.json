{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=sensorx_gateway;Username=postgres;Password=sk1234"
  },
  "JwtSettings": {
    "Issuer": "https://gateway.yourdomain.com",
    "Audience": "api",
    "AccessTokenMinutes": 15,
    "PrivateKeyPath": "Keys/private.key",
    "Kid": "key-2026-02",
    "HmacSecret": "CHANGE-THIS-TO-A-SECURE-RANDOM-SECRET-IN-PRODUCTION"
  },
  "Redis": {
    "ConnectionString": "localhost:6379,abortConnect=false"
  },
  "Security": {
    "MaxLoginAttempts": 5
  },
  "Cors": {
    "AllowedOrigins": [
      "https://app.yourdomain.com",
      "https://admin.yourdomain.com"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "data-route": {
        "ClusterId": "data-cluster",
        "Match": {
          "Path": "/Data/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/Data"
          }
        ]
      },
      "master-route": {
        "ClusterId": "master-cluster",
        "Match": {
          "Path": "/Master/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/Master"
          }
        ]
      },
      "warehouse-route": {
        "ClusterId": "warehouse-cluster",
        "Match": {
          "Path": "/Warehouse/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/Warehouse"
          }
        ]
      }
    },
    "Clusters": {
      "data-cluster": {
        "Destinations": {
          "data-service": {
            "Address": "http://product-service:8080/"
          }
        }
      },
      "master-cluster": {
        "Destinations": {
          "master-service": {
            "Address": "http://order-service:8080/"
          }
        }
      },
      "warehouse-cluster": {
        "Destinations": {
          "warehouse-service": {
            "Address": "http://inventory-service:8080/"
          }
        }
      }
    }
  },
  "OpenTelemetry": {
    "ServiceName": "sensorx-gateway",
    "OtlpEndpoint": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}