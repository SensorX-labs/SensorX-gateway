{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=sensorx_gateway;Username=postgres;Password=sk1234"
  },
  "JwtSettings": {
    "Issuer": "https://gateway.yourdomain.com",
    "Audience": "api",
    "AccessTokenMinutes": 15,
    "PrivateKeyPath": "Keys/private.key",
    "Kid": "key-2026-02",
    "HmacSecret": "CHANGE-THIS-TO-A-SECURE-RANDOM-SECRET-IN-PRODUCTION"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "Username": "guest",
    "Password": "guest"
  },
  "Security": {
    "MaxLoginAttempts": 5
  },
  "Cors": {
    "AllowedOrigins": [
      "https://app.yourdomain.com",
      "https://admin.yourdomain.com",
      "http://localhost:3000"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "master-route": {
        "ClusterId": "master-cluster",
        "Match": {
          "Path": "/api/master/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/master"
          },
          {
            "PathPrefix": "/api"
          }
        ]
      },
      "data-route": {
        "ClusterId": "data-cluster",
        "Match": {
          "Path": "/api/data/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/data"
          },
          {
            "PathPrefix": "/api"
          }
        ]
      },
      "warehouse-route": {
        "ClusterId": "warehouse-cluster",
        "Match": {
          "Path": "/api/warehouse/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/warehouse"
          },
          {
            "PathPrefix": "/api"
          }
        ]
      }
    },
    "Clusters": {
      "master-cluster": {
        "Destinations": {
          "master-service": {
            "Address": "http://master-api:8080/"
          }
        }
      },
      "data-cluster": {
        "Destinations": {
          "data-service": {
            "Address": "http://data-api:8080/"
          }
        }
      },
      "warehouse-cluster": {
        "Destinations": {
          "warehouse-service": {
            "Address": "http://warehouse-api:8080/"
          }
        }
      }
    }
  },
  "OpenTelemetry": {
    "ServiceName": "sensorx-gateway",
    "OtlpEndpoint": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}